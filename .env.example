# Copy this file to .env before a public deployment and change SECRET_KEY.
#
# For local testing you can run Docker Compose without this file because
# docker-compose.yml has development defaults.

FRONTEND_PORT=8080
VITE_API_BASE_URL=/api

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# For a real domain, set this to your public site origin, for example:
# FRONTEND_ORIGINS=https://your-domain.example
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

ENABLE_SCHEDULER=true
